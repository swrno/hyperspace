# ── Frontend (Vite, exposed to the browser — must be VITE_ prefixed) ──────────
# Firebase web app config. See src/vite-env.d.ts for the typed shape.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Deployed hypr-sdk docs site (linked from the app's Integration Code panel)
VITE_DOCS_URL=

# ── Backend (server.ts + api/**, loaded from .env / .env.local via dotenv) ────
PORT=3000
SYNC_INTERVAL_MINUTES=30
APP_BASE_URL=http://localhost:5173
ADMIN_EMAIL=

# Mongo (falls back to in-memory storage if unset/placeholder)
MONGODB_URI=

# Firebase ID-token verification (server-side). Falls back to VITE_FIREBASE_API_KEY.
FIREBASE_API_KEY=

# AES-256-GCM key for encrypting provider OAuth tokens at rest
TOKEN_ENC_KEY=

# Connector OAuth apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# Cognee (GraphRAG knowledge graph + retrieval)
COGNEE_BASE_URL=
COGNEE_API_KEY=

# LLM providers (chat falls back across these in order)
GROQ_API_KEY=
FIREWORKS_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
