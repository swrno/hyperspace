{
  "name": "hyperspace-web-ts",
  "version": "1.0.0",
  "description": "hypr enterprise knowledge engine — full TypeScript app (React UI + Express/Mongo/Cognee backend: auth, connectors, ingestion pipeline, retrieval layer).",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,web -c blue,green \"tsx watch server.ts\" \"vite\"",
    "dev:client": "vite",
    "dev:full": "concurrently -k -n server,web -c blue,green \"tsx watch server.ts\" \"vite\"",
    "server": "tsx watch server.ts",
    "start": "tsx server.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json"
  },
  "keywords": [
    "react",
    "typescript",
    "vite",
    "tailwind",
    "express",
    "mongodb",
    "knowledge-graph"
  ],
  "author": "Soumya",
  "license": "MIT",
  "dependencies": {
    "@react-sigma/core": "^5.0.6",
    "@react-sigma/layout-forceatlas2": "^5.0.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase": "^12.13.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-layout-forceatlas2": "^0.10.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.363.0",
    "mongodb": "^7.2.0",
    "neo4j-driver": "^6.2.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-force-graph-3d": "^1.29.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.15.1",
    "remark-gfm": "^4.0.1",
    "sigma": "^3.0.3",
    "three": "^0.185.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
